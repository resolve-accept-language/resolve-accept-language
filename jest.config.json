{
  "preset": "ts-jest",
  "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.d.ts", "!src/build-scripts/**"],
  "coverageThreshold": {
    "global": {
      "branches": 100,
      "functions": 100,
      "lines": 100,
      "statements": 100
    }
  },
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "tsconfig": "tests/tsconfig.json"
      }
    ]
  }
}
