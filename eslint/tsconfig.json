{
  "compilerOptions": {
    "rootDir": ".",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "tsBuildInfoFile": "/dev/null",
    "typeRoots": ["../node_modules/@types", "./"]
  },
  "include": ["../eslint.config.ts", "./**/*.ts"]
}
